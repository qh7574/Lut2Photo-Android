<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingTop="0dp"
        android:paddingRight="16dp"
        android:paddingBottom="0dp">

        <!-- 标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="0dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/text_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LUT管理"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium" />


        </LinearLayout>

        <!-- 操作栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="bottom"
                android:orientation="vertical"
                android:paddingTop="2dp">

                <TextView
                    android:id="@+id/text_lut_count"
                    style="@style/TextAppearance.Material3.BodyLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="共 0 个LUT文件"
                    android:textSize="16sp" />

                <TextView
                    style="@style/TextAppearance.Material3.DisplaySmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/LongPressPrompt"
                    android:textSize="12sp" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_import_lut"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="0dp"
                android:text="导入"
                app:icon="@drawable/outline_downloading_24" />

        </LinearLayout>

        <!-- LUT文件列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_luts"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- 底部多选控制条 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/selection_toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:visibility="gone"
        app:cardCornerRadius="0dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardElevation="8dp">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="8dp">

                <!-- 返回按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_exit_selection"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="-8dp"
                    android:text="返回"
                    app:icon="@drawable/ic_close_24" />

                <!-- 全选按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_select_all"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="-8dp"
                    android:text="全选"
                    app:icon="@drawable/ic_select_all_24" />

                <!-- 取消选择按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_deselect_all"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="0dp"
                    android:text="取消"
                    app:icon="@drawable/ic_deselect_24" />

                <!-- 导出按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_export"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="导出"
                    app:icon="@drawable/ic_menu_upload" />

                <!-- 删除按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_delete"
                    style="@style/Widget.Material3.Button.IconButton.Filled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="?attr/colorError"
                    android:text="删除"
                    app:icon="@drawable/ic_delete_24" />

            </LinearLayout>

        </HorizontalScrollView>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>